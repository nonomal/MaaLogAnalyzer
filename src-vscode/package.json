{
  "name": "maa-log-analyzer",
  "displayName": "Maa Log Analyzer",
  "description": "Maa Log Analyzer - Analyze MaaFramework log files",
  "version": "0.0.1",
  "publisher": "Windsland52",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaaXYZ/MaaLogAnalyzer"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "maaLogAnalyzer.openAnalyzer",
        "title": "Maa: 打开日志分析器"
      },
      {
        "command": "maaLogAnalyzer.analyzeFile",
        "title": "Maa: 分析此日志文件"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "maaLogAnalyzer.analyzeFile",
          "when": "resourceExtname == .log || resourceFilename =~ /maa.*\\.log/i",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "maaLogAnalyzer.analyzeFile",
          "when": "resourceExtname == .log",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build:webview": "cd .. && pnpm build:vscode",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}

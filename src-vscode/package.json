{
  "name": "maa-log-analyzer",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.0.1",
  "publisher": "Windsland52",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaaXYZ/MaaLogAnalyzer"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onUri"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "maaLogAnalyzer.openAnalyzer",
        "title": "%command.openAnalyzer%"
      },
      {
        "command": "maaLogAnalyzer.analyzeFolder",
        "title": "%command.analyzeFolder%"
      },
      {
        "command": "maaLogAnalyzer.analyzeFile",
        "title": "%command.analyzeFile%"
      },
      {
        "command": "maaLogAnalyzer.installContextMenu",
        "title": "%command.installContextMenu%"
      },
      {
        "command": "maaLogAnalyzer.uninstallContextMenu",
        "title": "%command.uninstallContextMenu%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maaLogAnalyzer",
          "title": "%viewsContainer.maa%",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "maaLogAnalyzer": [
        {
          "id": "maaLogAnalyzer.sidebar",
          "name": "%view.logAnalyzer%"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "maaLogAnalyzer.analyzeFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "maaLogAnalyzer.analyzeFile",
          "when": "resourceExtname == .log || resourceFilename =~ /maa.*\\.log/i",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "maaLogAnalyzer.analyzeFile",
          "when": "resourceExtname == .log",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "maaLogAnalyzer.openAnalyzer",
          "when": "view == maaLogAnalyzer.sidebar && viewItem == openAnalyzer",
          "group": "inline"
        },
        {
          "command": "maaLogAnalyzer.analyzeFolder",
          "when": "view == maaLogAnalyzer.sidebar && viewItem == analyzeFolder",
          "group": "inline"
        },
        {
          "command": "maaLogAnalyzer.installContextMenu",
          "when": "view == maaLogAnalyzer.sidebar && viewItem == installContextMenu && isWindows",
          "group": "inline"
        },
        {
          "command": "maaLogAnalyzer.uninstallContextMenu",
          "when": "view == maaLogAnalyzer.sidebar && viewItem == uninstallContextMenu && isWindows",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "maaLogAnalyzer.installContextMenu",
          "when": "isWindows"
        },
        {
          "command": "maaLogAnalyzer.uninstallContextMenu",
          "when": "isWindows"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:webview && npm run compile",
    "compile": "npm run typecheck && npm run bundle",
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js --sourcemap",
    "watch": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --target=node18 --external:vscode --outfile=dist/extension.js --sourcemap --watch",
    "build:webview": "cd .. && pnpm build:vscode",
    "package": "vsce package"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.25.10",
    "typescript": "^5.3.0"
  }
}
